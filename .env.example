# Supabase – aus deinem Supabase-Projekt unter Project Settings → API kopieren
# Diese Datei ist eine Vorlage. Lege eine echte ".env" an und trage dort deine Werte ein.
# Die echte ".env" wird über .gitignore NICHT eingecheckt (Secrets bleiben lokal).

VITE_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-key
